# Public app URL used by deployment previews and external callbacks.
VITE_APP_URL=https://pn.yogeshaihub.in

# Current app mode. Keep "local" until a production backend is connected.
VITE_STORAGE_MODE=local

# Optional Forms API base URL for cross-device public forms and shared responses.
# Expected routes: PUT/GET /forms/:slug and POST/GET /forms/:slug/responses.
VITE_FORMS_API_URL=

# Optional admin login overrides. Store only a SHA-256 hash, never plaintext.
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD_SHA256=

# Optional external tools. Add real production values in Coolify environment variables.
VITE_GOOGLE_SHEETS_URL=
VITE_WHATSAPP_PHONE_NUMBER=
